{
  "name": "aura-ai",
  "version": "1.1.1",
  "description": "Aura AI — a local-first AI chat companion with personas, image chat, persistent memory, and web awareness.",
  "main": "out/main/index.js",
  "license": "MIT",
  "author": "Aura AI contributors",
  "homepage": "https://github.com/eisenjimmy/AuraAI",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:ko": "AURA_EDITION=ko electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "start": "electron-vite preview",
    "llm:gemma4-v2": "scripts/start-jarvis-gemma4-v2.sh",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:en:mac": "AURA_EDITION=en electron-vite build && electron-builder --mac",
    "dist:en:win": "AURA_EDITION=en electron-vite build && electron-builder --win --x64 --arm64",
    "dist:ko:mac": "AURA_EDITION=ko electron-vite build && electron-builder --mac -c.appId=app.aura.chat.ko -c.productName='Aura AI Korean' -c.artifactName='Aura AI Korean-${version}-${os}-${arch}.${ext}'",
    "dist:ko:win": "AURA_EDITION=ko electron-vite build && electron-builder --win --x64 --arm64 -c.appId=app.aura.chat.ko -c.productName='Aura AI Korean' -c.artifactName='Aura AI Korean-${version}-${os}-${arch}.${ext}'"
  },
  "dependencies": {
    "kokoro-js": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "app.aura.chat",
    "productName": "Aura AI",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!**/._*",
      "!**/.DS_Store"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
